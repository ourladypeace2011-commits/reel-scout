# Reel Scout — Environment Configuration
# Copy to .env and fill in values

# --- Paths ---
# REEL_SCOUT_DATA=./data

# --- VLM ---
# VLM_BACKEND=omlx
# VLM_MODEL=
# OMLX_BASE_URL=http://localhost:8000/v1
# OLLAMA_BASE_URL=http://localhost:11434

# --- LLM ---
# LLM_BACKEND=omlx
# LLM_MODEL=
# OPENCLAW_BASE_URL=http://localhost:18789/v1
# OPENCLAW_MODEL=

# --- Whisper ---
# WHISPER_BACKEND=faster-whisper
# WHISPER_MODEL=large-v3

# --- Crawl ---
# IG_COOKIES_FILE=
# RATE_LIMIT_PER_MINUTE=10

# --- Vision ---
# KEYFRAME_STRATEGY=scene
# KEYFRAME_MAX=8

# --- External tools ---
# FFMPEG_BIN=ffmpeg

# --- Speaker Diarization ---
DIARIZE_ENABLED=false
# PYANNOTE_AUTH_TOKEN=  # HuggingFace token (required for pyannote)

# --- Optional ---
# WEBHOOK_URL=
