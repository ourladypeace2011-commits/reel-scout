# Reel Scout Configuration

# Data directory (default: ./data)
# REEL_SCOUT_DATA=./data

# VLM Backend: "omlx" or "ollama"
VLM_BACKEND=omlx
VLM_MODEL=

# oMLX (OpenAI-compatible)
OMLX_BASE_URL=http://localhost:8000/v1

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Whisper Backend: "faster-whisper" or "whisper-cpp"
WHISPER_BACKEND=faster-whisper
WHISPER_MODEL=large-v3

# Instagram cookies file (Netscape format)
# IG_COOKIES_FILE=~/.ig_cookies.txt

# Rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=10

# Keyframe extraction
KEYFRAME_STRATEGY=scene
KEYFRAME_MAX=8

# FFmpeg binary path
# FFMPEG_BIN=ffmpeg

# Webhook (optional)
# WEBHOOK_URL=
